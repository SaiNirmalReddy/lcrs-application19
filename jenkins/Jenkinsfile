pipeline {
    agent any

    stages {

        stage('SonarQube Scan') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh '/opt/sonar-scanner/bin/sonar-scanner'
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t sai1docker/lcrs-app -f docker/Dockerfile .'
            }
        }

        stage('Push Docker Image') {
            steps {
                sh 'docker push sai1docker/lcrs-app'

        stage('Trivy Scan') {
           steps {
               sh 'trivy fs .'
            }
        }

    }
}
